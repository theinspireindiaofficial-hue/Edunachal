# Copy this file to ".env.local" and paste your real key.
# ".env.local" is git-ignored, so the secret key never gets committed.
#
# Where to find it: Supabase -> Project Settings -> API -> "service_role" (secret) key.
# This key has full write access — it is ONLY used by the local import script,
# never shipped to the website.

SUPABASE_SERVICE_KEY=paste-your-service-role-secret-key-here
